{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ezstream",
  "version": "0.1.3",
  "identifier": "com.ezstream.app",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "EZStream",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/YOUR_GITHUB_USERNAME/ezstream/main/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxMTMzMTFGMDU2QkNCQgpSV1M3dkZid0VUTVJETTZPZU5rRXZmS0lSS0xXYXgzUGdrcjdWdkVoUkNTWUg2ak5xb1VCdVI2WAo="
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "resources": [
      "../api-dist/**/*"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}