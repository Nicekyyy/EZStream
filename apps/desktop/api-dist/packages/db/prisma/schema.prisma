generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CREATOR
  ADMIN
}

enum WidgetType {
  ALERT_WIDGET
  TTS_WIDGET
  GOAL_WIDGET
  EVENT_LIST_WIDGET
  CHAT_WIDGET
  IMAGE_WIDGET
  SOUND_WIDGET
  TEXT_WIDGET
  VIEWER_COUNT_WIDGET
}

enum EventStatus {
  RECEIVED
  MATCHED
  PROCESSED
  FAILED
}

enum WidgetActionStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum TtsJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum ChatPlatform {
  TIKTOK
  YOUTUBE
}

enum ChatSourceStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  ERROR
}

enum MediaAssetType {
  IMAGE
  AUDIO
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(CREATOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creator  Creator?
  apiTokens ApiToken[]
  auditLogs AuditLog[]
}

model Creator {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  slug        String   @unique
  bio         String?
  settings    Json     @default(dbgenerated("'{}'"))
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  overlays      Overlay[]
  widgets       Widget[]
  eventLogs     EventLog[]
  widgetActions WidgetAction[]
  ttsJobs       TtsJob[]
  mediaAssets   MediaAsset[]
  apiTokens     ApiToken[]
  liveSessions  LiveSession[]
  auditLogs     AuditLog[]
  chatSources   ChatSource[]
}

model Overlay {
  id          String   @id @default(cuid())
  creatorId   String
  name        String
  token       String   @unique
  width       Int      @default(1920)
  height      Int      @default(1080)
  isActive    Boolean  @default(true)
  config      Json     @default(dbgenerated("'{}'"))
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator      Creator      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  widgets      Widget[]
  liveSessions LiveSession[]
  chatSources  ChatSource[]

  @@index([creatorId])
}

model Widget {
  id         String     @id @default(cuid())
  creatorId  String
  overlayId  String?
  type       WidgetType
  name       String
  isEnabled  Boolean    @default(true)
  positionX  Int        @default(0)
  positionY  Int        @default(0)
  width      Int        @default(400)
  height     Int        @default(160)
  zIndex     Int        @default(1)
  visibility Boolean    @default(true)
  config     Json       @default(dbgenerated("'{}'"))
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  creator       Creator        @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  overlay       Overlay?       @relation(fields: [overlayId], references: [id], onDelete: SetNull)
  state         WidgetState?
  actions       WidgetAction[]
  ttsJobs       TtsJob[]

  @@index([creatorId])
  @@index([overlayId])
  @@index([type])
}

model WidgetState {
  id        String   @id @default(cuid())
  widgetId  String   @unique
  state     Json     @default(dbgenerated("'{}'"))
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  widget Widget @relation(fields: [widgetId], references: [id], onDelete: Cascade)
}

model EventLog {
  id             String      @id @default(cuid())
  creatorId      String
  liveSessionId  String?
  eventType      String
  status         EventStatus @default(RECEIVED)
  payload        Json
  matchedRuleIds String      @default("[]")
  errorMessage   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  creator       Creator        @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  liveSession   LiveSession?   @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)
  widgetActions WidgetAction[]
  ttsJobs       TtsJob[]

  @@index([creatorId])
  @@index([liveSessionId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
}

model WidgetAction {
  id           String             @id @default(cuid())
  creatorId    String
  widgetId     String
  eventLogId   String?
  actionType   String
  status       WidgetActionStatus @default(QUEUED)
  payload      Json               @default(dbgenerated("'{}'"))
  errorMessage String?
  runAt        DateTime?
  completedAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  creator  Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  widget   Widget    @relation(fields: [widgetId], references: [id], onDelete: Cascade)
  eventLog EventLog? @relation(fields: [eventLogId], references: [id], onDelete: SetNull)

  @@index([creatorId])
  @@index([widgetId])
  @@index([eventLogId])
  @@index([status])
  @@index([createdAt])
}

model TtsJob {
  id           String       @id @default(cuid())
  creatorId    String
  widgetId     String?
  eventLogId   String?
  status       TtsJobStatus @default(QUEUED)
  text         String
  voice        String       @default("default")
  speed        Float        @default(1)
  pitch        Float        @default(1)
  volume       Float        @default(1)
  payload      Json         @default(dbgenerated("'{}'"))
  errorMessage String?
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  creator  Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  widget   Widget?   @relation(fields: [widgetId], references: [id], onDelete: SetNull)
  eventLog EventLog? @relation(fields: [eventLogId], references: [id], onDelete: SetNull)

  @@index([creatorId])
  @@index([widgetId])
  @@index([eventLogId])
  @@index([status])
  @@index([createdAt])
}

model MediaAsset {
  id           String         @id @default(cuid())
  creatorId    String
  type         MediaAssetType
  fileName     String
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  publicPath   String
  metadata     Json           @default(dbgenerated("'{}'"))
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([type])
}

model AuditLog {
  id         String   @id @default(cuid())
  creatorId  String?
  userId     String?
  action     String
  resource   String
  resourceId String?
  metadata   Json     @default(dbgenerated("'{}'"))
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  creator Creator? @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([creatorId])
  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
}

model ApiToken {
  id          String    @id @default(cuid())
  creatorId   String
  userId      String
  name        String
  tokenHash   String    @unique
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([userId])
  @@index([revokedAt])
}

model LiveSession {
  id           String    @id @default(cuid())
  creatorId    String
  overlayId    String?
  externalId   String?
  title        String?
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  metadata     Json      @default(dbgenerated("'{}'"))
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  creator   Creator    @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  overlay   Overlay?   @relation(fields: [overlayId], references: [id], onDelete: SetNull)
  eventLogs EventLog[]

  @@index([creatorId])
  @@index([overlayId])
  @@index([startedAt])
}

model ChatSource {
  id              String           @id @default(cuid())
  creatorId       String
  overlayId       String
  platform        ChatPlatform
  target          String
  label           String?
  status          ChatSourceStatus @default(DISCONNECTED)
  isEnabled       Boolean          @default(true)
  config          Json             @default(dbgenerated("'{}'"))
  errorMessage    String?
  lastConnectedAt DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  creator         Creator          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  overlay         Overlay          @relation(fields: [overlayId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([overlayId])
  @@index([status])
}
