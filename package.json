{
  "name": "ezstream",
  "version": "1.1.2",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"pnpm --filter @ezstream/web dev\" \"pnpm --filter @ezstream/api dev\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "dotenv -e .env -- pnpm --filter @ezstream/db db:generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @ezstream/db db:migrate",
    "db:seed": "dotenv -e .env -- pnpm --filter @ezstream/db db:seed",
    "desktop:prep": "node scripts/prepare-desktop.js",
    "desktop:dev": "pnpm desktop:prep && pnpm --filter @ezstream/desktop tauri dev",
    "desktop:dev:all": "concurrently -n web,desktop -c cyan,blue \"pnpm --filter @ezstream/web dev\" \"pnpm desktop:dev\"",
    "desktop:build": "pnpm build && pnpm desktop:prep && pnpm --filter @ezstream/desktop tauri build",
    "desktop:signer": "pnpm --filter @ezstream/desktop exec tauri signer generate"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^8.0.0",
    "pake-cli": "^3.12.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "overrides": {
      "multer": "^2.2.0",
      "esbuild": "^0.28.1",
      "protobufjs": "^7.6.3",
      "shell-quote": "^1.8.4",
      "form-data": "^4.0.6",
      "ws": "^8.21.0",
      "postcss": "^8.5.10",
      "qs": "^6.15.2"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  }
}