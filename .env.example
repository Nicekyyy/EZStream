NODE_ENV=development

DATABASE_URL=postgresql://ezstream:ezstream@localhost:55432/ezstream?schema=public
REDIS_URL=redis://localhost:56379

JWT_SECRET=replace-with-a-secure-random-secret
JWT_EXPIRES_IN=7d

WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

API_PORT=4000
API_CORS_ORIGIN=http://localhost:3000
LOCAL_STORAGE_ROOT=./storage
API_PUBLIC_URL=http://localhost:4000

GOOGLE_TTS_LANGUAGE_CODE=th-TH
GOOGLE_TTS_VOICE=th-TH-Neural2-C
# Use either GOOGLE_APPLICATION_CREDENTIALS or GOOGLE_TTS_SERVICE_ACCOUNT_JSON.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_TTS_SERVICE_ACCOUNT_JSON=
# Optional short-lived OAuth token for local testing.
GOOGLE_TTS_ACCESS_TOKEN=

WORKER_CONCURRENCY=5
